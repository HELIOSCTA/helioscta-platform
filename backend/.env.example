# Azure Postgres writer credentials for backend scrape/upsert jobs.
# Use the helios_writer role created by infrastructure/azure-postgres.
AZURE_POSTGRES_WRITER_HOST=
AZURE_POSTGRES_WRITER_USER=helios_writer
AZURE_POSTGRES_WRITER_PASSWORD=
AZURE_POSTGRES_WRITER_PORT=5432
AZURE_POSTGRES_WRITER_DBNAME=helios_prod
AZURE_POSTGRES_WRITER_SSLMODE=require

# PJM Data Miner
PJM_API_KEY=
