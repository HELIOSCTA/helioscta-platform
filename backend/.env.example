# Azure Postgres app-owner credentials for backend scrape/upsert jobs.
# Use helios_admin after running infrastructure/azure-postgres bootstrap.
AZURE_POSTGRES_WRITER_HOST=
AZURE_POSTGRES_WRITER_USER=helios_admin
AZURE_POSTGRES_WRITER_PASSWORD=
AZURE_POSTGRES_WRITER_PORT=5432
AZURE_POSTGRES_WRITER_DBNAME=helios_prod
AZURE_POSTGRES_WRITER_SSLMODE=require

# Read-only dbt credentials used by production health digest data tests.
DBT_POSTGRES_HOST=
DBT_POSTGRES_READONLY_USER=helios_readonly
DBT_POSTGRES_READONLY_PASSWORD=
DBT_POSTGRES_PORT=5432
DBT_POSTGRES_DBNAME=helios_prod
DBT_POSTGRES_SSLMODE=require

# Optional on Linux VMs. Defaults to ./logs under each script directory.
HELIOS_LOG_DIR=/var/log/helioscta

# PJM Data Miner
PJM_API_KEY=

# ERCOT Public API
ERCOT_USERNAME=
ERCOT_PASSCODE=
ERCOT_API_KEY=

# WSI Trader weather feeds
WSI_TRADER_USERNAME=
WSI_TRADER_NAME=
WSI_TRADER_PASSWORD=
