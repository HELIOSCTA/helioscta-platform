[Unit]
Description=HeliosCTA NAV trade breaks scheduled SFTP email poll
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=helios
Group=helios
WorkingDirectory=/opt/helioscta-platform
EnvironmentFile=/etc/helioscta/backend.env
ExecStart=/usr/bin/flock -n /tmp/helios-nav-trade-breaks.lock /opt/helioscta-platform/.venv/bin/python -c "from backend.orchestration.nav import trade_breaks_email; raise SystemExit(trade_breaks_email.scheduled_main(lookback_days=1, poll_wait_seconds=300, poll_window_minutes=420, poll_deadline_hour=11, metadata={'scheduler':'systemd'}))"
TimeoutStartSec=7h30min
StandardOutput=journal
StandardError=journal
SyslogIdentifier=helios-nav-trade-breaks

[Install]
WantedBy=multi-user.target
