[Unit]
Description=HeliosCTA ISO-NE Day-Ahead Hourly LMP orchestration
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=helios
Group=helios
WorkingDirectory=/opt/helioscta-platform
EnvironmentFile=/etc/helioscta/backend.env
ExecStart=/usr/bin/flock -n /tmp/helios-isone-da-hrl-lmps.lock /opt/helioscta-platform/.venv/bin/python -m backend.orchestration.power.isone.da_hrl_lmps
TimeoutStartSec=5h
StandardOutput=journal
StandardError=journal
SyslogIdentifier=helios-isone-da-hrl-lmps

[Install]
WantedBy=multi-user.target
