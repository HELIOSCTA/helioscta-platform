[Unit]
Description=HeliosCTA ERCOT outage and capacity support batch
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=helios
Group=helios
WorkingDirectory=/opt/helioscta-platform
EnvironmentFile=/etc/helioscta/backend.env
ExecStart=/usr/bin/flock -n /tmp/helios-ercot-outage-capacity-batch.lock /opt/helioscta-platform/.venv/bin/python -m backend.orchestration.power.ercot.outage_capacity_batch
Nice=5
NoNewPrivileges=true
